# Frontend Environment Configuration
# Copy file ini ke .env.local dan isi nilai yang sesuai

# Backend API URL
VITE_BACKEND_URL=http://localhost:8081/api

# ============================================================
# MIDTRANS CONFIGURATION (WAJIB untuk pembayaran non-tunai)
# ============================================================
# Dapatkan kunci dari: https://dashboard.sandbox.midtrans.com
# Settings -> Access Keys -> Client Key (untuk frontend)
VITE_MIDTRANS_CLIENT_KEY=SB-Mid-client-xxxxxxxxxxxxxx

# Gunakan false untuk mode Sandbox (testing), true untuk Produksi
VITE_MIDTRANS_IS_PRODUCTION=false
